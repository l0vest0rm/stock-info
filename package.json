{
  "name": "stock-info",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:prompts": "node scripts/build-prompts.mjs",
    "dev": "npm run build:prompts && npm run build:web && node scripts/dev-worker-local.mjs",
    "dev:worker": "npm run build:prompts && node scripts/dev-worker-local.mjs",
    "dev:worker:bare": "wrangler dev --local",
    "dev:web": "cd web && vite --config vite.layout.config.ts",
    "build": "npm run build:prompts && npm run build:web",
    "build:web": "cd web && node scripts/build-html.mjs && vite build --config vite.layout.config.ts && node scripts/build-vue-pages.mjs && node scripts/build-legacy-pages.mjs",
    "deploy": "./deploy-cloudflare.sh",
    "deploy:cloudflare": "./deploy-cloudflare.sh",
    "rollback:cloudflare": "./rollback-cloudflare.sh",
    "import:knowledge:docs": "node scripts/import-knowledge-docs.mjs",
    "import:knowledge:docs:remote": "node scripts/import-knowledge-docs-remote.mjs",
    "import:knowledge:docs:remote:latest": "node scripts/import-knowledge-docs-remote-latest.mjs",
    "import:knowledge:filtered": "node scripts/import-filtered-knowledge-docs.mjs",
    "import:knowledge:filtered:remote": "node scripts/import-filtered-knowledge-docs-remote.mjs",
    "import:knowledge:filtered:remote:latest": "node scripts/import-filtered-knowledge-docs-remote-latest.mjs",
    "migrate:knowledge:localfs": "node scripts/migrate-localfs-knowledge-content.mjs --apply --upload-content-remote",
    "cleanup:knowledge:docs:local": "node scripts/cleanup-knowledge-docs.mjs --local --apply",
    "cleanup:knowledge:docs:remote": "node scripts/cleanup-knowledge-docs.mjs --remote --apply",
    "cleanup:knowledge:docs:local:dry-run": "node scripts/cleanup-knowledge-docs.mjs --local --dry-run",
    "cleanup:knowledge:docs:remote:dry-run": "node scripts/cleanup-knowledge-docs.mjs --remote --dry-run",
    "cleanup:knowledge:content": "node scripts/cleanup-knowledge-content.mjs --remote --dry-run",
    "cleanup:knowledge:content:apply": "node scripts/cleanup-knowledge-content.mjs --remote --apply",
    "report:cloudflare:observability": "node scripts/report-cloudflare-observability.mjs",
    "preflight:cloudflare:release": "./scripts/preflight-cloudflare-release.sh",
    "process:knowledge": "npm run build:prompts && node scripts/process-knowledge-once.mjs",
    "process:knowledge:local:full": "npm run build:prompts && node scripts/process-knowledge-local-full.mjs",
    "stats:knowledge:storage": "node scripts/report-knowledge-storage.mjs",
    "check:cloudflare:token": "node scripts/verify-cloudflare-token.mjs",
    "test:smoke:pages": "node scripts/smoke-pages.mjs",
    "seed:knowledge:sample": "node scripts/seed-knowledge-sample.mjs",
    "typecheck": "npm run build:prompts && tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply stock_info --local",
    "db:migrate:remote": "wrangler d1 migrations apply stock_info --remote"
  },
  "dependencies": {
    "@m2ai/shared-llm-client": "file:../shared-ts/packages/llm-client",
    "@vitejs/plugin-vue": "^6.0.3",
    "echarts": "^6.0.0",
    "hono": "^4.12.27",
    "vite": "^7.2.7",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.8",
    "wrangler": "^4.23.0"
  }
}
