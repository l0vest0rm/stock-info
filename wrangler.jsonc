{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stock-info",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "vars": {
    "APP_VERSION": "0.1.0",
    "LLM_DAILY_LIMIT": "300",
    "HTTP_PROXY_URL": "",
    "HTTP_PROXY_DOMAINS": "",
    "HTTP_DOMAIN_CONCURRENCY": "3",
  },
  "assets": {
    "directory": "./web/dist",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/company-option.html", "/knowledge-config.html", "/cdn-cgi/handler/scheduled"],
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "stock_info",
      "database_id": "6bbdca28-28da-42c2-9186-bb57f29bb7bc",
    },
  ],
  "triggers": {
    "crons": ["17 1 * * *"],
  },
}
